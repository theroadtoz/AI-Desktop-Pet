# Default local-first setup requires no API key and no env provider override.
# Keep these values unset when using the embedded packaged local model.

# Optional local OpenAI-compatible service override:
# AI_DESKTOP_PET_PROVIDER=local-openai-compatible
# AI_DESKTOP_PET_BASE_URL=http://127.0.0.1:8080/v1
# AI_DESKTOP_PET_MODEL=ai-desktop-pet-local
# AI_DESKTOP_PET_TEMPERATURE=0.7
# AI_DESKTOP_PET_MAX_TOKENS=240
# AI_DESKTOP_PET_TIMEOUT_MS=60000

# Optional cloud fallback example:
# AI_DESKTOP_PET_PROVIDER=openai-compatible
# AI_DESKTOP_PET_BASE_URL=https://api.deepseek.com
# AI_DESKTOP_PET_MODEL=deepseek-v4-flash
# AI_DESKTOP_PET_API_KEY=
